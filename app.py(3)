@app.route('/cantinho')
@login_necessario
def cantinho():
    nome = session.get('usuario_nome')

    # Bônus - contador de visitas
    visitas = session.get('visitas_cantinho', 0)
    visitas += 1
    session['visitas_cantinho'] = visitas

    return render_template(
        'cantinho.html',
        nome=nome,
        cor='Azul',               # Troque pela sua cor favorita
        linguagem='Python',       # Troque pela sua linguagem favorita
        frase='Nunca pare de aprender!',  # Troque pela sua frase
        visitas=visitas
    )
